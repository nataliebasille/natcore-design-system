{
  "name": "@nataliebasille/natcore-design-system",
  "version": "2.0.0",
  "description": "Natcore Design System core package for Tailwind CSS 4.0+",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./css": {
      "style": "./dist/natcore.css",
      "default": "./dist/natcore.css"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js",
      "require": "./dist/plugin.cjs",
      "default": "./dist/plugin.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js",
      "require": "./dist/utils.cjs",
      "default": "./dist/utils.js"
    }
  },
  "scripts": {
    "build": "tsx scripts/build.ts",
    "watch": "tsx ../core-v2/scripts/watch.ts",
    "clean": "rimraf dist",
    "type-check": "tsc --noEmit"
  },
  "author": "Natalie Basille",
  "license": "MIT",
  "peerDependencies": {
    "tailwindcss": "^4.1.16"
  },
  "dependencies": {
    "@nataliebasille/natcore-css-engine": "workspace:*",
    "chroma-js": "^3.2.0",
    "classnames": "^2.5.1",
    "culori": "^4.0.2",
    "next-themes": "^0.4.6"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.16",
    "@types/chroma-js": "^3.1.2",
    "@types/culori": "^4.0.1",
    "@types/node": "^22.19.0",
    "rimraf": "^6.1.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
